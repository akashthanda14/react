generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DOCKER_DATABASE_URL")
}

model User {
  id               String                @id @default(cuid())
  email            String                @unique
  name             String
  image            String?
  password         String?
  currentStreak    Int                   @default(0)
  longestStreak    Int                   @default(0)
  lastActivityDate DateTime?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  accounts         Account[]
  sessions         Session[]
  userRoadmaps     UserRoadmap[]
  role             Role                  @default(USER)

  @@index([email])
  @@map("users")
}

enum Role {
  USER
  ADMIN
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}


// ============================================
// ROADMAP MODELS
// ============================================

// Engineering Track (Backend, DevOps, System Design, GenAI)
model Track {
  id          String   @id @default(cuid())
  name        String   @unique // "Backend / Fullstack Engineer"
  slug        String   @unique // "backend"
  description String?
  icon        String?  // Icon identifier
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  phases       Phase[]
  userRoadmaps UserRoadmap[]

  @@index([slug])
  @@map("tracks")
}

// Phase within a track (Fundamentals, Architecture Patterns, etc.)
model Phase {
  id          String   @id @default(cuid())
  name        String   // "Fundamentals"
  description String?  // "Core concepts every engineer must know"
  outcome     String?  // "Build and deploy a CRUD API"
  order       Int      @default(0)
  trackId     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  track      Track       @relation(fields: [trackId], references: [id], onDelete: Cascade)
  skills     Skill[]
  milestones Milestone[]

  @@index([trackId])
  @@index([order])
  @@map("phases")
}

// Skill/Topic within a phase (HTTP, REST APIs, Databases, etc.)
model Skill {
  id          String   @id @default(cuid())
  name        String   // "REST APIs"
  description String?  // "Design and build RESTful APIs"
  order       Int      @default(0)
  phaseId     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  phase Phase @relation(fields: [phaseId], references: [id], onDelete: Cascade)

  @@index([phaseId])
  @@index([order])
  @@map("skills")
}

// Milestone checkpoint within a phase
model Milestone {
  id          String   @id @default(cuid())
  title       String   // "Build a REST API with CRUD operations"
  description String?  // Additional context
  order       Int      @default(0)
  phaseId     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  phase            Phase                   @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  userMilestones   UserMilestoneProgress[]
  questions        MilestoneQuestion[]

  @@index([phaseId])
  @@index([order])
  @@map("milestones")
}

// User's assigned roadmap
model UserRoadmap {
  id                String   @id @default(cuid())
  userId            String
  trackId           String
  experienceLevel   String?  // "1-2 years of experience"
  timeCommitment    String?  // "4-6 hours per week"
  startedAt         DateTime @default(now())
  completedAt       DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  user              User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  track             Track                   @relation(fields: [trackId], references: [id], onDelete: Cascade)
  milestoneProgress UserMilestoneProgress[]

  @@unique([userId, trackId])
  @@index([userId])
  @@index([trackId])
  @@map("user_roadmaps")
}

// User's progress on individual milestones
model UserMilestoneProgress {
  id            String    @id @default(cuid())
  userRoadmapId String
  milestoneId   String
  completedAt   DateTime?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  userRoadmap UserRoadmap @relation(fields: [userRoadmapId], references: [id], onDelete: Cascade)
  milestone   Milestone   @relation(fields: [milestoneId], references: [id], onDelete: Cascade)

  @@unique([userRoadmapId, milestoneId])
  @@index([userRoadmapId])
  @@index([milestoneId])
  @@map("user_milestone_progress")
}

// ============================================
// MILESTONE VALIDATION MODELS
// ============================================

// Validation question for a milestone
model MilestoneQuestion {
  id          String   @id @default(cuid())
  milestoneId String
  question    String   // "What HTTP method is used for creating resources?"
  type        QuestionType @default(MULTIPLE_CHOICE)
  explanation String?  // Optional explanation shown after answering
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  milestone Milestone              @relation(fields: [milestoneId], references: [id], onDelete: Cascade)
  options   MilestoneAnswerOption[]

  @@index([milestoneId])
  @@index([order])
  @@map("milestone_questions")
}

// Answer option for multiple choice questions
model MilestoneAnswerOption {
  id         String   @id @default(cuid())
  questionId String
  text       String   // "POST"
  isCorrect  Boolean  @default(false)
  order      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  
  question MilestoneQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
  @@index([order])
  @@map("milestone_answer_options")
}

enum QuestionType {
  MULTIPLE_CHOICE
  TRUE_FALSE
  SHORT_ANSWER
}
